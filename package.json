{
  "name": "metadata-components",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --project=metadata-components",
    "build_xx": "ng run metadata-components:build",
    "build_mc": "rm -rf dist/ngx-metadata-components && ng build ngx-metadata-components",
    "build": "npm run build_mc && npm run start",
    "npm_publish": "cd dist/ngx-metadata-components && npm publish --access public",
    "lint": "eslint \"src/**/*.ts\" \"projects/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"projects/**/*.ts\" --fix",
    "lint:js": "eslint \"**/*.js\"",
    "lint:js:fix": "eslint \"**/*.js\" --fix"
  },
  "dependencies": {
    "@angular/animations": "^20.0.6",
    "@angular/common": "^20.0.6",
    "@angular/compiler": "^20.0.6",
    "@angular/core": "^20.0.6",
    "@angular/forms": "^20.0.6",
    "@angular/material": "^20.0.6",
    "@angular/platform-browser": "^20.0.6",
    "@angular/platform-browser-dynamic": "^20.0.6",
    "@angular/router": "^20.0.6",
    "@iqb/metadata": "^1.4.1",
    "@iqb/metadata-resolver": "^0.1.0",
    "@ngx-formly/core": "^7.0.0",
    "@ngx-formly/material": "^7.0.0",
    "@ngx-translate/core": "^15.0.0",
    "ngx-build-plus": "^20.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.6",
    "@angular/cli": "^20.0.6",
    "@angular/compiler-cli": "^20.0.6",
    "@angular/elements": "^20.0.6",
    "@iqb/eslint-config": "^2.0.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "esbuild": "^0.27.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.0.6",
    "typescript": "5.9.3",
    "zone.js": "^0.15.1"
  },
  "eslintConfig": {
    "overrides": [
      {
        "files": [
          "*.ts"
        ],
        "extends": "@iqb/eslint-config",
        "parserOptions": {
          "project": "./tsconfig.json"
        }
      },
      {
        "files": [
          "*.js"
        ],
        "extends": "@iqb/eslint-config/javascript"
      }
    ]
  }
}
