{
  "name": "metadata-components",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --project=metadata-components",
    "build_xx": "ng run metadata-components:build",
    "build_mc": "rm -rf dist/ngx-metadata-components && ng build ngx-metadata-components",
    "build": "npm run build_mc && npm run start",
    "npm_publish": "cd dist/ngx-metadata-components && npm publish --access public",
    "test:ci": "ng test ngx-metadata-components --watch=false --browsers=ChromeHeadless",
    "lint": "eslint \"src/**/*.ts\" \"projects/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"projects/**/*.ts\" --fix",
    "lint:js": "eslint \"**/*.js\"",
    "lint:js:fix": "eslint \"**/*.js\" --fix"
  },
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/material": "20.2.14",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@iqb/metadata-resolver": "^0.2.0",
    "@iqbspecs/metadata-profile": "^0.11.1",
    "@iqbspecs/metadata-values": "^3.0.1",
    "@ngx-formly/core": "^7.0.0",
    "@ngx-formly/material": "^7.0.0",
    "@ngx-translate/core": "^15.0.0",
    "ngx-build-plus": "^20.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.31",
    "@angular/cli": "20.3.31",
    "@angular/compiler-cli": "20.3.25",
    "@angular/elements": "20.3.25",
    "@iqb/eslint-config": "^2.0.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "esbuild": "^0.27.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-plugin-import": "^2.32.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "20.3.2",
    "typescript": "5.9.3",
    "zone.js": "^0.15.1"
  },
  "eslintConfig": {
    "overrides": [
      {
        "files": [
          "*.ts"
        ],
        "extends": "@iqb/eslint-config",
        "parserOptions": {
          "project": "./tsconfig.json"
        }
      },
      {
        "files": [
          "*.js"
        ],
        "extends": "@iqb/eslint-config/javascript"
      }
    ]
  }
}
